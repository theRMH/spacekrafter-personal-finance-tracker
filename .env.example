# Copy this file to .env.local and fill in real values from
# Supabase dashboard -> Settings -> API. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only. Bypasses Row Level Security — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection, used only by scripts/run-migration.mjs.
DATABASE_URL=postgresql://user:password@host:port/postgres
